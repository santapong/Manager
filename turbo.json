{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local", ".env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "DATABASE_URL",
        "AUTH_SECRET",
        "AUTH_URL",
        "AUTH_TRUST_HOST",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "RESEND_API_KEY",
        "EMAIL_FROM",
        "ABLY_API_KEY",
        "SENTRY_DSN",
        "SENTRY_ENVIRONMENT",
        "AXIOM_TOKEN",
        "AXIOM_DATASET",
        "HEALTH_TOKEN",
        "DEV_LOGIN_TOKEN",
        "VERCEL_ENV",
        "VERCEL_GIT_COMMIT_SHA"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URL"]
    },
    "clean": {
      "cache": false
    }
  }
}
