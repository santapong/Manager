# Copy to .env.local and fill in. Required vars without defaults make `pnpm build` fail.

# --- database ---
# Neon Postgres connection string (pooled, with ?sslmode=require)
DATABASE_URL=

# --- auth ---
# 32+ char random string. Generate: `openssl rand -base64 32`
AUTH_SECRET=
# Set to true on Vercel previews; defaults to false locally
AUTH_TRUST_HOST=false
# Optional — auto-detected on Vercel
AUTH_URL=

# GitHub OAuth app credentials. Optional in dev (magic link still works).
# Create at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- email ---
# Resend API key. If unset, magic link URLs are logged to the server console
# (development convenience only — production builds will warn loudly).
RESEND_API_KEY=
EMAIL_FROM="Manager <noreply@example.com>"

# --- observability ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Defaults to VERCEL_ENV on Vercel deployments
SENTRY_ENVIRONMENT=
AXIOM_TOKEN=
AXIOM_DATASET=

# --- ops ---
# Required for /api/health/deep — generate any opaque random string
HEALTH_TOKEN=

# --- integrations ---
# Static bearer token for the `/api/v1/*` REST surface and the MCP server.
# v1 shortcut: a single shared secret. Personal Access Tokens (per-user,
# argon2id-hashed, scoped) are the planned follow-up. If unset, every v1
# call returns 503 `auth_not_configured` (auth never silently disabled).
# Generate: `openssl rand -base64 32`
MANAGER_API_KEY=

# --- app ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
