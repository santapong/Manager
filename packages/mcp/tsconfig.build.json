{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "incremental": false
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/__tests__/**", "**/*.test.ts", "vitest.config.ts"]
}
